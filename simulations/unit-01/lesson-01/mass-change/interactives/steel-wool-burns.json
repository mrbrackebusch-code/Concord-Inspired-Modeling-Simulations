  "components": [
    {
      "type": "text",
      "id": "burns-note",
      "text": "Weigh the steel wool, start the burn, then record the final mass after the visible change finishes."
    },
    {
      "type": "button",
      "id": "burns-before-button",
      "text": "Weigh (before)",
      "action": "loadModel('burns-before-measured');"
    },
    {
      "type": "button",
      "id": "burns-start-button",
      "text": "Start burning",
      "action": "loadModel('burns-open-live-1');",
      "disabled": true
    },
    {
      "type": "button",
      "id": "burns-after-button",
      "text": "Weigh (after)",
      "action": "loadModel('burns-open-after');",
      "disabled": true
    },
    {
      "type": "button",
      "id": "burns-reset-button",
      "text": "Reset",
      "action": "loadModel('burns-ready-step');",
      "disabled": true
    }
  ],
  "layout": {
